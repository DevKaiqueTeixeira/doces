{
  "name": "docesjeh",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n front,api -c green,blue \"vite\" \"tsx watch server/index.ts\"",
    "dev:front": "vite",
    "dev:api": "tsx watch server/index.ts",
    "build": "vue-tsc -b && vite build && tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "db:flyway:version": "powershell -ExecutionPolicy Bypass -File scripts/flyway.ps1 version",
    "db:flyway:info": "powershell -ExecutionPolicy Bypass -File scripts/flyway.ps1 info",
    "db:flyway:migrate": "powershell -ExecutionPolicy Bypass -File scripts/flyway.ps1 migrate",
    "db:flyway:validate": "powershell -ExecutionPolicy Bypass -File scripts/flyway.ps1 validate"
  },
  "dependencies": {
    "@quasar/extras": "^2.0.2",
    "@supabase/supabase-js": "^2.57.4",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "pinia": "^3.0.3",
    "quasar": "^2.18.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vue": "^3.5.39",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@quasar/vite-plugin": "^1.10.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.8.22",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^9.2.1",
    "tsx": "^4.20.5",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vue-tsc": "^3.3.5"
  }
}
